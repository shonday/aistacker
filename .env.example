# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env.local for local development
#
#   cp .env.example .env.local
#
# .env.local is git-ignored. Never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
# Used by next-sitemap and canonical URL generation.
# In production this is set in the Cloudflare Pages dashboard.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Future FastAPI backend (optional) ─────────────────────────────────────────
# Only needed when a tool sets apiEndpoint in data/tools.ts.
# Leave blank for fully client-side deployments.
NEXT_PUBLIC_API_BASE=

# ─────────────────────────────────────────────────────────────────────────────
# Generator LLM keys (scripts/generate-tool.ts only)
# These are read by Node.js at script runtime — NOT exposed to the browser.
# You only need ONE provider. Priority: Ollama → Gemini → Anthropic → Groq
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (local, free, recommended for offline use) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
