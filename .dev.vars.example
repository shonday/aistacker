# ─────────────────────────────────────────────────────────────────────────────
# .dev.vars.example — copy to .dev.vars for Cloudflare Workers local preview
#
#   cp .dev.vars.example .dev.vars
#
# Used by: npx wrangler dev  /  npm run preview
# .dev.vars is git-ignored. Never commit real keys.
#
# Note: NEXT_PUBLIC_* vars belong in .env.local, not here.
# This file is only for server-side secrets that Cloudflare Workers can read.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE=
